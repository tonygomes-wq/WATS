# Permitir acesso a arquivos de mídia do chat
<IfModule mod_rewrite.c>
    RewriteEngine Off
</IfModule>

# Permitir CORS para imagens
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, OPTIONS"
</IfModule>

# Tipos MIME
<IfModule mod_mime.c>
    AddType image/jpeg .jpg .jpeg
    AddType image/png .png
    AddType image/gif .gif
    AddType image/webp .webp
    AddType video/mp4 .mp4
    AddType audio/ogg .ogg
    AddType audio/mpeg .mp3
</IfModule>

# Cache de imagens (7 dias)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 7 days"
    ExpiresByType image/png "access plus 7 days"
    ExpiresByType image/gif "access plus 7 days"
    ExpiresByType image/webp "access plus 7 days"
    ExpiresByType video/mp4 "access plus 7 days"
    ExpiresByType audio/ogg "access plus 7 days"
    ExpiresByType audio/mpeg "access plus 7 days"
</IfModule>
